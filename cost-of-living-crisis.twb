      <aliases enabled='yes' />
      <column caption='Essentials to Salary %' datatype='real' default-format='p0%' name='[Calculation_1248623037749514240]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_1656761753728417793]/IFNULL([median_salary],0)' />
      </column>
      <column caption='Affordability Tier ' datatype='string' name='[Calculation_1248623037750276097]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='if [affordability_score]&gt;= 75 THEN &quot;HIGH (75-100)&quot;&#13;&#10;ELSEIF [affordability_score]&gt;= 50 THEN &quot;MEDIUM (50-74)&quot;&#13;&#10;ELSE&quot;LOW (&lt;50)&quot;&#13;&#10;END' />
      </column>
      <column caption='City (Formatted) ( for nice labels)' datatype='string' name='[Calculation_1248623037751099394]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[city]+ &quot;(&quot;+ [country]+&quot;)&quot;' />
      </column>
      <column caption='Rank (Top N) – Ascending (for bottom list)' datatype='integer' name='[Calculation_1248623037752549379]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RANK(SUM([affordability_score]), &apos;asc&apos;)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Rank (Top N) – Descending' datatype='integer' name='[Calculation_1248623037753982980]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RANK(SUM([affordability_score]), &apos;desc&apos;)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='donut helper ' datatype='integer' name='[Calculation_1248623037772849159]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='1' />
      </column>
      <column caption='Total Essentials Cost (USD)' datatype='real' name='[Calculation_1248623037775126538]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[rent_usd_proxy]+ [grocery_item_price_median]+ [utilities_usd_proxy]' />
      </column>
      <column caption='Rent % of Essentials' datatype='real' name='[Calculation_1248623037775294475]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[rent_usd_proxy]/ [Calculation_1248623037775126538]' />
      </column>
      <column caption='Groceries % of Essentials' datatype='real' name='[Calculation_1248623037775417356]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[grocery_item_price_median]/[Calculation_1248623037775126538]' />
      </column>
      <column caption='Utilities % of Essentials' datatype='real' name='[Calculation_1248623037775540237]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[utilities_usd_proxy]/[Calculation_1248623037775126538]' />
      </column>
      <column caption='Essential Cost (USD)' datatype='real' name='[Calculation_1656761753728417793]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='ZN([rent_usd_proxy])+ ZN([utilities_usd_proxy])+ ZN([grocery_item_price_median])' />
      </column>
      <column caption='Affordability Tier' datatype='string' name='[Calculation_1656761753728815106]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [affordability_score]&gt;= 75 THEN &quot;HIGH (75-100)&quot;&#13;&#10;ELSEIF [affordability_score]&gt;= 50 THEN &quot;MEDIUM (50-74)&quot;&#13;&#10;ELSE &quot;LOW (&lt;50)&quot; &#13;&#10;END' />
      </column>
      <column caption='top bottom label ' datatype='string' name='[Calculation_2257147879744057345]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF ([City Set])THEN &quot;TOP 10&quot;&#13;&#10;ELSEIF ([City Set 2]) THEN &quot;BOTTOM 10&quot;&#13;&#10;ELSE &quot;OTHER&quot;&#13;&#10;END' />
      </column>
      <column caption='rent to salary %' datatype='real' name='[Calculation_498210749942398977]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[rent_usd_proxy]/ [Calculation_1248623037775126538]* 100' />
      </column>
      <column caption='alary vs Cost Gap' datatype='boolean' name='[Calculation_498210749954224130]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[salary_pr]= [average_salary]- [Calculation_1656761753728417793]' />
      </column>
