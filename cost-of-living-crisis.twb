            </customized-tooltip>
            <customized-label>
              <formatted-text>
                <run bold='true' fontsize='20'>&lt;</run>
                <run bold='true' fontsize='20'>[federated.01ods2h1wf629m1bzxo0s10bfq2g].[sum:Calculation_1248623037749514240:qk]</run>
