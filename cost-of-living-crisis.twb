    <worksheet name='KPI – Avg Essentials %.'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontname='Sitka Heading Semibold' fontsize='12'>Avg % of Salary on Essentials</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='final project assigment csv' name='federated.01ods2h1wf629m1bzxo0s10bfq2g' />
          </datasources>
          <datasource-dependencies datasource='federated.01ods2h1wf629m1bzxo0s10bfq2g'>
            <column caption='Essentials to Salary %' datatype='real' default-format='p0%' name='[Calculation_1248623037749514240]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[Calculation_1656761753728417793]/IFNULL([median_salary],0)' />
            </column>
            <column caption='Essential Cost (USD)' datatype='real' name='[Calculation_1656761753728417793]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='ZN([rent_usd_proxy])+ ZN([utilities_usd_proxy])+ ZN([grocery_item_price_median])' />
            </column>
            <column caption='Grocery Item Price Median' datatype='real' name='[grocery_item_price_median]' role='measure' type='quantitative' />
            <column caption='Median Salary' datatype='real' name='[median_salary]' role='measure' type='quantitative' />
            <column caption='Rent Usd Proxy' datatype='real' name='[rent_usd_proxy]' role='measure' type='quantitative' />
            <column-instance column='[Calculation_1248623037749514240]' derivation='Sum' name='[sum:Calculation_1248623037749514240:qk]' pivot='key' type='quantitative' />
            <column caption='Utilities Usd Proxy' datatype='real' name='[utilities_usd_proxy]' role='measure' type='quantitative' />
          </datasource-dependencies>
          <aggregation value='true' />
        </view>
        <style />
        <panes>
          <pane selection-relaxation-option='selection-relaxation-allow'>
            <view>
              <breakdown value='auto' />
            </view>
            <mark class='Automatic' />
            <encodings>
              <text column='[federated.01ods2h1wf629m1bzxo0s10bfq2g].[sum:Calculation_1248623037749514240:qk]' />
            </encodings>
