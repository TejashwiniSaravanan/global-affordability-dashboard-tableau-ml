            <column-instance column='[city]' derivation='None' name='[none:city:nk]' pivot='key' type='nominal' />
            <column caption='Rent Usd Proxy' datatype='real' name='[rent_usd_proxy]' role='measure' type='quantitative' />
            <column caption='Salary Pr' datatype='real' name='[salary_pr]' role='measure' type='quantitative' />
